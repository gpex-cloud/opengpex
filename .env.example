# ==============================================================================
# OpenGPEX Plugin System & Environment Feature Configuration Template
# ==============================================================================

# Host Runtime Mode (SaaS Cloud vs Self-hosted Private Deployment)
# - true: Activate SaaS cloud mode, physical backend API strictly blocks (403 Forbidden) any dynamic plugin uploads, and Hub panel hides upload area.
# - false (or unset): Activate local personal/private self-hosted mode, allowing sideloading, uploading, and managing dynamic ZIP plugins.
NEXT_PUBLIC_GPEX_CLOUD_MODE=true
GPEX_CLOUD_MODE=$NEXT_PUBLIC_GPEX_CLOUD_MODE
